# =============================================================================
# Clear / ClearPath app — environment template
# Copy to `app/.env.local` for local dev. For deploys, set these in the dashboards:
#   • VITE_* (this file)  → FRONTEND, set in VERCEL (Project → Settings → Environment Variables)
#   • backend vars (bottom) → set in RAILWAY (the app/server service). See app/server/env.example.
# Vite only exposes VITE_-prefixed vars to the browser. NEVER put server secrets in a VITE_ var.
# =============================================================================

# ----------------------------------------------------------------------------
# FRONTEND  (Vercel)
# ----------------------------------------------------------------------------

# Backend API base — the deployed app/server URL on Railway. REQUIRED in prod;
# without it the app calls http://localhost:3001 and shows no data.
VITE_API_BASE_URL=https://your-server.up.railway.app

# Reown AppKit project id (wallet auth / SIWX). Must match the backend's REOWN_PROJECT_ID.
VITE_APPKIT_PROJECT_ID=

# CLRUSD token (so Savings shows). Set the deployed CLRUSD address per chain you support.
# Base mainnet = 8453, Base Sepolia = 84532. USDC is already known (config/tokens.ts).
VITE_CLRUSD_HOME_CHAIN_ID=8453
VITE_CLRUSD_8453=0x0000000000000000000000000000000000000000
VITE_CLRUSD_84532=0x0000000000000000000000000000000000000000
# (add VITE_CLRUSD_<chainId> for any other chains you enable)

# Embedded Persona KYC (in-app widget). Leave blank to keep the mock KYC flow.
VITE_PERSONA_TEMPLATE_ID=
VITE_PERSONA_ENVIRONMENT_ID=

# Turn on real Bridge/Persona/Plaid client calls (lib/integrations). Leave unset/false until the
# backend Bridge customer-create + Persona webhook routes exist; otherwise mocks are used.
VITE_INTEGRATIONS_LIVE=false

# Optional: frontend RPC URLs (balances go through the backend, so usually NOT needed).
# VITE_ALCHEMY_BASE_MAINNET=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# =============================================================================
# BACKEND  (Railway — app/server)  ·  set these in Railway, NOT in this file.
# Full reference: app/server/env.example. The ones that matter for the app to work:
#
#   ALCHEMY_API_KEY=            # ← makes USDC/CLRUSD balances + on-chain tx work
#   REDIS_URL=                  # ← ONE Redis (Upstash recommended); drop the duplicate service
#   DATABASE_URL=               # ← Postgres; required so linked Plaid items survive restarts
#   REOWN_PROJECT_ID=           # ← must equal VITE_APPKIT_PROJECT_ID (gates /api/plaid,/bridge,/stripe)
#   CORS_ORIGIN=                # ← your Vercel app URL (e.g. https://app.useclear.org)
#   CLRUSD_8453= / CLRUSD_84532=  # ← same CLRUSD addresses as the VITE_ ones above
#
#   # Plaid (bank linking + balances)
#   PLAID_CLIENT_ID=  PLAID_SECRET=  PLAID_ENV=sandbox  PLAID_REDIRECT_URI=
#   PLAID_TOKEN_MASTER_KEY=      # openssl rand -base64 32
#
#   # Bridge (KYC + virtual accounts + funding)
#   BRIDGE_API_KEY=  BRIDGE_API_BASE_URL=https://api.sandbox.bridge.xyz/v0
#
#   # Persona (NEW — needed for the embedded KYC → Bridge backend loop, once built)
#   PERSONA_API_KEY=  PERSONA_WEBHOOK_SECRET=
#
#   # Stripe on-ramp / membership billing (optional)
#   STRIPE_SECRET_KEY=  STRIPE_*_PRICE_ID=  STRIPE_MEMBERSHIP_WEBHOOK_SECRET=
# =============================================================================
