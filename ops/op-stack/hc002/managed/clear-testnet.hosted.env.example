# Signers
SEQUENCER_PRIVATE_KEY=0xREPLACE_SEQUENCER_KEY
BATCHER_PRIVATE_KEY=0xREPLACE_BATCHER_KEY
PROPOSER_PRIVATE_KEY=0xREPLACE_PROPOSER_KEY

# Service-specific OP Stack vars
OP_BATCHER_L1_ETH_RPC=https://eth-sepolia.g.alchemy.com/v2/REPLACE_API_KEY
OP_PROPOSER_L1_ETH_RPC=https://eth-sepolia.g.alchemy.com/v2/REPLACE_API_KEY

# OP Stack contract addresses (from state.applied.json / rollup.json)
